# Копия на сервере: переименуйте в .env или задайте переменные в панели / .htaccess (SetEnv).

# Каталог с данными: папки проектов, logo.jpg, файл менеджеров и т.д.
SHOP_ROOT_DIR=/absolute/path/to/shop_root

# Порт для локального запуска (на Beget Passenger обычно задаёт PORT сам).
PORT=5177

NODE_ENV=production
